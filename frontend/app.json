        "backgroundColor": "#FFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
