{
  "expo": {
    "name": "mtb_game",
    "slug": "mtb_game",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mtb_game",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
